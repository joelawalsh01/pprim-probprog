<mujoco model="spiral_tube">
  <option timestep="0.002" gravity="0 0 0" integrator="RK4"/>
  <!-- No gravity: isolate the curvilinear impetus question -->

  <asset>
    <material name="ground" rgba="0.12 0.12 0.18 1" specular="0" shininess="0"/>
    <!-- Tube walls invisible in MuJoCo render; canvas draws smooth walls instead -->
    <material name="tube_outer" rgba="0 0 0 0" specular="0" shininess="0"/>
    <material name="tube_inner" rgba="0 0 0 0" specular="0" shininess="0"/>
  </asset>

