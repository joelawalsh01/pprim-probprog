<mujoco model="spiral_tube">
  <option timestep="0.002" gravity="0 0 0" integrator="RK4"/>
  <!-- No gravity: isolate the curvilinear impetus question -->

  <asset>
    <material name="ground" rgba="0.12 0.12 0.18 1" specular="0" shininess="0"/>
    <material name="tube_outer" rgba="0.4 0.4 0.5 0.7" specular="0.2" shininess="0.3"/>
    <material name="tube_inner" rgba="0.3 0.35 0.45 0.6" specular="0.1" shininess="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 5" dir="0 0 -1" diffuse="0.8 0.8 0.8" castshadow="false"/>
    <light pos="0 -3 3" dir="0 0.5 -0.5" diffuse="0.4 0.4 0.5"/>

    <!-- Ground reference plane (visual only) -->
    <geom type="plane" size="5 5 0.01" material="ground" contype="0" conaffinity="0"/>

    <!-- Curved channel: quarter-circle arc, radius ~1m -->
    <!-- Outer wall (radius 1.12) — 8 segments for smooth appearance -->
    <geom type="capsule" size="0.03 0.18" pos="-1.12 0 0.05" euler="0 90 0" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.18" pos="-1.06 0 0.25" euler="0 90 12" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.18" pos="-0.95 0 0.48" euler="0 90 25" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.18" pos="-0.78 0 0.70" euler="0 90 38" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.18" pos="-0.56 0 0.88" euler="0 90 52" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.18" pos="-0.32 0 1.00" euler="0 90 65" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.18" pos="-0.10 0 1.08" euler="0 90 78" material="tube_outer" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.12" pos="0.08 0 1.10" euler="0 90 85" material="tube_outer" contype="0" conaffinity="0"/>

    <!-- Inner wall (radius 0.88) — 8 segments -->
    <geom type="capsule" size="0.03 0.16" pos="-0.88 0 0.05" euler="0 90 0" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.16" pos="-0.84 0 0.22" euler="0 90 12" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.16" pos="-0.75 0 0.42" euler="0 90 25" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.16" pos="-0.62 0 0.60" euler="0 90 38" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.16" pos="-0.44 0 0.76" euler="0 90 52" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.16" pos="-0.25 0 0.88" euler="0 90 65" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.16" pos="-0.08 0 0.95" euler="0 90 78" material="tube_inner" contype="0" conaffinity="0"/>
    <geom type="capsule" size="0.03 0.10" pos="0.06 0 0.98" euler="0 90 85" material="tube_inner" contype="0" conaffinity="0"/>

    <!-- Exit arrow: small indicator showing the tube opening direction -->
    <geom type="capsule" size="0.015 0.12" pos="0.25 0 1.05" euler="0 90 90" rgba="0.5 0.8 0.5 0.6" contype="0" conaffinity="0"/>

    <!-- The ball: starts at bottom of arc, scripted simulation moves it through -->
    <body name="ball" pos="-1.0 0 0.05">
      <joint type="free" damping="0"/>
      <geom type="sphere" size="0.06" mass="0.5" rgba="1.0 0.5 0.2 1"
            contype="0" conaffinity="0"/>
      <site name="force_point" pos="0 0 0" size="0.01"/>
    </body>

    <!-- Cameras -->
    <camera name="side" pos="0 -4 0.8" xyaxes="1 0 0 0 0.3 1"/>
    <camera name="top" pos="0 0 5" xyaxes="1 0 0 0 1 0"/>
  </worldbody>

  <actuator>
    <motor name="push_force" site="force_point" gear="1 0 0 0 0 0"
           ctrllimited="true" ctrlrange="-10 10"/>
  </actuator>

  <sensor>
    <framepos name="ball_pos" objtype="body" objname="ball"/>
    <framelinvel name="ball_vel" objtype="body" objname="ball"/>
  </sensor>
</mujoco>
