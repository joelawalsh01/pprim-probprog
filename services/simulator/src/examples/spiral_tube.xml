    <geom type="capsule" size="0.03 0.0288" pos="-0.0288 0 0.9291" euler="0 90 1.9" material="tube_inner" contype="0" conaffinity="0"/>

    <!-- Exit arrow invisible in MuJoCo; canvas draws exit marker -->
    <geom type="capsule" size="0.015 0.12" pos="0.25 0 1.05" euler="0 90 90" rgba="0 0 0 0" contype="0" conaffinity="0"/>

    <!-- The ball: starts at bottom of arc, scripted simulation moves it through -->
    <body name="ball" pos="-1.0 0 0.05">
      <joint type="free" damping="0"/>
      <geom type="sphere" size="0.06" mass="0.5" rgba="1.0 0.5 0.2 1"
            contype="0" conaffinity="0"/>
      <site name="force_point" pos="0 0 0" size="0.01"/>
    </body>

    <!-- Cameras -->
    <camera name="side" pos="0 -4 0.8" xyaxes="1 0 0 0 0.3 1"/>
    <camera name="top" pos="0 0 5" xyaxes="1 0 0 0 1 0"/>
  </worldbody>

  <actuator>
    <motor name="push_force" site="force_point" gear="1 0 0 0 0 0"
           ctrllimited="true" ctrlrange="-10 10"/>
  </actuator>

  <sensor>
    <framepos name="ball_pos" objtype="body" objname="ball"/>
    <framelinvel name="ball_vel" objtype="body" objname="ball"/>
  </sensor>
